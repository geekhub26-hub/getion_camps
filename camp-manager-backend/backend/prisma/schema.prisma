// ============================================================
//  Camp Manager — Schéma Prisma
//  Stack : PostgreSQL + Prisma ORM
//  Généré pour le projet de gestion de camp d'adolescents
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  ANIMATEUR
  PARENT
}

enum StatutCamp {
  BROUILLON
  OUVERT
  COMPLET
  EN_COURS
  TERMINE
  ANNULE
}

enum StatutInscription {
  EN_ATTENTE
  CONFIRME
  ANNULE
  LISTE_ATTENTE
}

enum StatutPaiement {
  EN_ATTENTE
  PARTIEL
  PAYE
  REMBOURSE
  ANNULE
}

enum MethodePaiement {
  ESPECES
  VIREMENT
  MOBILE_MONEY
  CARTE_BANCAIRE
  CHEQUE
}

enum StatutAnimateur {
  ACTIF
  INACTIF
  SUSPENDU
}

enum TypeDocument {
  AUTORISATION_PARENTALE
  FICHE_SANTE
  PHOTO_IDENTITE
  CERTIFICAT_MEDICAL
  AUTRE
}

enum StatutDocument {
  EN_ATTENTE
  VALIDE
  REJETE
}

enum TypeNotification {
  PAIEMENT_RELANCE
  DOCUMENT_MANQUANT
  ACTIVITE_RAPPEL
  INSCRIPTION_CONFIRMEE
  MESSAGE_RECU
  ANNONCE_GENERALE
}

enum RelationParent {
  PERE
  MERE
  TUTEUR
  AUTRE
}

enum TypePresence {
  ANIMATEUR
  ENFANT
}

// ─────────────────────────────────────────
//  USER — Comptes d'accès
// ─────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  nom              String
  prenom           String
  email            String    @unique
  motDePasseHash   String    @map("mot_de_passe_hash")
  role             Role      @default(PARENT)
  avatarUrl        String?   @map("avatar_url")
  actif            Boolean   @default(true)
  dernierLogin     DateTime? @map("dernier_login")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  messagesEnvoyes  Message[]      @relation("expediteur")
  notifications    Notification[]

  @@map("users")
}

// ─────────────────────────────────────────
//  CAMP — Session de camp
// ─────────────────────────────────────────

model Camp {
  id           String     @id @default(uuid())
  nom          String
  description  String?
  lieu         String
  adresse      String?
  dateDebut    DateTime   @map("date_debut")
  dateFin      DateTime   @map("date_fin")
  capaciteMax  Int        @map("capacite_max")
  prixBase     Decimal    @default(0) @map("prix_base") @db.Decimal(10, 2)
  statut       StatutCamp @default(BROUILLON)
  imageUrl     String?    @map("image_url")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relations
  participants    Participant[]
  animateurs      Animateur[]
  groupes         Groupe[]
  activites       Activite[]
  messages        Message[]
  notifications   Notification[]
  statsSnapshots  StatistiqueSnap[]
  depenses        Depense[]
  fichePresences  FichePresence[]
  visiteurs       Visiteur[]
  dons            Don[]
  paroisses       CampParoisse[]
  enseignements   Enseignement[]

  @@map("camps")
}

// ─────────────────────────────────────────
//  CAMP PAROISSE — Paroisses d'un camp
// ─────────────────────────────────────────

model CampParoisse {
  id              String   @id @default(uuid())
  campId          String   @map("camp_id")
  nom             String
  responsable     String?
  telephone       String?
  prixParticipant Decimal? @map("prix_participant") @db.Decimal(10, 2)

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("camp_paroisses")
}

// ─────────────────────────────────────────
//  PARTICIPANT — Adolescent inscrit
// ─────────────────────────────────────────

model Participant {
  id                String            @id @default(uuid())
  campId            String            @map("camp_id")
  nom               String
  prenom            String
  dateNaissance     DateTime          @map("date_naissance")
  lieuNaissance     String?           @map("lieu_naissance")
  genre             String?
  nationalite       String?
  niveauScolaire    String?           @map("niveau_scolaire")
  participationsAnterieures Int?      @default(0) @map("participations_anterieures")
  contactAdolescent String?           @map("contact_adolescent")
  paroisse          String?
  responsableParoisse  String?        @map("responsable_paroisse")
  responsableTelephone String?        @map("responsable_telephone")
  groupeSanguin     String?           @map("groupe_sanguin")
  infosMedicales    String?           @map("infos_medicales")
  allergies         String?
  medicaments       String?
  nomUrgence        String            @map("nom_urgence")
  telephoneUrgence  String            @map("telephone_urgence")
  statutInscription StatutInscription @default(EN_ATTENTE) @map("statut_inscription")
  dispense          Boolean           @default(false)
  numeroChambre     String?           @map("numero_chambre")
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  camp        Camp                 @relation(fields: [campId], references: [id], onDelete: Cascade)
  parents     Parent[]
  paiements   Paiement[]
  documents   Document[]
  groupes     ParticipantGroupe[]
  articlesSac ArticleSac[]

  @@map("participants")
}

// ─────────────────────────────────────────
//  PARENT — Contact parental
// ─────────────────────────────────────────

model Parent {
  id            String         @id @default(uuid())
  participantId String         @map("participant_id")
  nom           String
  prenom        String
  email         String
  telephone     String
  telephone2    String?
  relation      RelationParent @default(PERE)
  principal     Boolean        @default(false)
  createdAt     DateTime       @default(now()) @map("created_at")

  // Relations
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@map("parents")
}

// ─────────────────────────────────────────
//  ANIMATEUR — Membre du personnel
// ─────────────────────────────────────────

model Animateur {
  id          String          @id @default(uuid())
  nom         String
  prenom      String
  campId      String          @map("camp_id")
  specialite  String?
  telephone   String?
  missions    String?
  statut      StatutAnimateur @default(ACTIF)
  dateArrivee DateTime?       @map("date_arrivee")
  dateDepart  DateTime?       @map("date_depart")
  createdAt   DateTime        @default(now()) @map("created_at")

  // Relations
  camp        Camp       @relation(fields: [campId], references: [id], onDelete: Cascade)
  activites   Activite[]
  groupes     Groupe[]

  @@map("animateurs")
}

// ─────────────────────────────────────────
//  GROUPE — Sous-groupe dans un camp
// ─────────────────────────────────────────

model Groupe {
  id          String   @id @default(uuid())
  campId      String   @map("camp_id")
  nom         String
  couleur     String   @default("#6366f1")
  categorie   String?
  animateurId String?  @map("animateur_id")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  camp         Camp                @relation(fields: [campId], references: [id], onDelete: Cascade)
  animateur    Animateur?          @relation(fields: [animateurId], references: [id])
  participants ParticipantGroupe[]
  activites    ActiviteGroupe[]

  @@map("groupes")
}

// ─────────────────────────────────────────
//  PARTICIPANT_GROUPE — Jonction many-to-many
// ─────────────────────────────────────────

model ParticipantGroupe {
  participantId String   @map("participant_id")
  groupeId      String   @map("groupe_id")
  assigneAt     DateTime @default(now()) @map("assigne_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  groupe      Groupe      @relation(fields: [groupeId], references: [id], onDelete: Cascade)

  @@id([participantId, groupeId])
  @@map("participant_groupes")
}

// ─────────────────────────────────────────
//  ACTIVITE — Planning des activités
// ─────────────────────────────────────────

model Activite {
  id             String   @id @default(uuid())
  campId         String   @map("camp_id")
  animateurId    String?  @map("animateur_id")
  titre          String
  description    String?
  lieu           String?
  dateHeureDebut DateTime @map("date_heure_debut")
  dateHeureFin   DateTime @map("date_heure_fin")
  capaciteMax    Int?     @map("capacite_max")
  couleur        String   @default("#0ea5e9")
  materiel       String?
  statut         String   @default("PLANIFIE")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  camp       Camp             @relation(fields: [campId], references: [id], onDelete: Cascade)
  animateur  Animateur?       @relation(fields: [animateurId], references: [id])
  groupes    ActiviteGroupe[]

  @@map("activites")
}

// ─────────────────────────────────────────
//  ACTIVITE_GROUPE — Jonction many-to-many
// ─────────────────────────────────────────

model ActiviteGroupe {
  activiteId String @map("activite_id")
  groupeId   String @map("groupe_id")

  activite Activite @relation(fields: [activiteId], references: [id], onDelete: Cascade)
  groupe   Groupe   @relation(fields: [groupeId], references: [id], onDelete: Cascade)

  @@id([activiteId, groupeId])
  @@map("activite_groupes")
}

// ─────────────────────────────────────────
//  PAIEMENT — Suivi financier
// ─────────────────────────────────────────

model Paiement {
  id            String          @id @default(uuid())
  participantId String?         @map("participant_id")
  campId        String?         @map("camp_id")
  libelle       String?
  montant       Decimal         @db.Decimal(10, 2)
  montantTotal  Decimal?        @map("montant_total") @db.Decimal(10, 2)
  statut        StatutPaiement  @default(EN_ATTENTE)
  methode       MethodePaiement @default(ESPECES)
  reference     String?
  datePaiement  DateTime?       @map("date_paiement")
  notes         String?
  recu          Boolean         @default(false)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("paiements")
}

// ─────────────────────────────────────────
//  DEPENSE — Sorties financières du camp
// ─────────────────────────────────────────

model Depense {
  id          String   @id @default(uuid())
  campId      String   @map("camp_id")
  libelle     String
  categorie   String
  montant     Decimal  @db.Decimal(10, 2)
  dateDepense DateTime @default(now()) @map("date_depense")
  reference   String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("depenses")
}

// ─────────────────────────────────────────
//  DOCUMENT — Pièces jointes
// ─────────────────────────────────────────

model Document {
  id            String         @id @default(uuid())
  participantId String         @map("participant_id")
  nom           String
  type          TypeDocument
  urlFichier    String         @map("url_fichier")
  statut        StatutDocument @default(EN_ATTENTE)
  tailleFichier Int?           @map("taille_fichier")
  mimeType      String?        @map("mime_type")
  notes         String?
  uploadedAt    DateTime       @default(now()) @map("uploaded_at")
  valideAt      DateTime?      @map("valide_at")

  // Relations
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─────────────────────────────────────────
//  MESSAGE — Communication admin ↔ parents
// ─────────────────────────────────────────

model Message {
  id           String   @id @default(uuid())
  campId       String   @map("camp_id")
  expediteurId String   @map("expediteur_id")
  parentId     String?  @map("parent_id")
  sujet        String
  contenu      String
  lu           Boolean  @default(false)
  envoye       Boolean  @default(true)
  envoyeAt     DateTime @default(now()) @map("envoye_at")
  luAt         DateTime? @map("lu_at")

  // Relations
  camp       Camp      @relation(fields: [campId], references: [id], onDelete: Cascade)
  expediteur User      @relation("expediteur", fields: [expediteurId], references: [id])
  parent     Parent?   @relation(fields: [parentId], references: [id])

  @@map("messages")
}

// ─────────────────────────────────────────
//  NOTIFICATION — Alertes système
// ─────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  destinataireId String           @map("destinataire_id")
  campId         String?          @map("camp_id")
  titre          String
  message        String
  type           TypeNotification
  lue            Boolean          @default(false)
  lienAction     String?          @map("lien_action")
  createdAt      DateTime         @default(now()) @map("created_at")
  luAt           DateTime?        @map("lu_at")

  // Relations
  destinataire User  @relation(fields: [destinataireId], references: [id], onDelete: Cascade)
  camp         Camp? @relation(fields: [campId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────
//  STATISTIQUE_SNAP — Snapshots pour dashboard
// ─────────────────────────────────────────

model StatistiqueSnap {
  id                 String   @id @default(uuid())
  campId             String   @map("camp_id")
  dateSnap           DateTime @map("date_snap")
  totalParticipants  Int      @map("total_participants")
  totalConfirmes     Int      @map("total_confirmes")
  totalPaye          Int      @map("total_paye")
  revenusTotal       Decimal  @map("revenus_total") @db.Decimal(10, 2)
  revenusCibles      Decimal  @map("revenus_cibles") @db.Decimal(10, 2)
  activitesCount     Int      @map("activites_count")
  documentsValides   Int      @map("documents_valides")
  documentsPending   Int      @map("documents_pending")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("statistique_snaps")
}

// ─────────────────────────────────────────
//  FICHE_PRESENCE — Sorties/retours encadrants & enfants
// ─────────────────────────────────────────

model FichePresence {
  id           String       @id @default(uuid())
  campId       String       @map("camp_id")
  type         TypePresence @default(ANIMATEUR)
  nom          String
  prenom       String
  heureSortie  DateTime     @map("heure_sortie")
  motif        String
  heureRetour  DateTime?    @map("heure_retour")
  signature    String?
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("fiches_presence")
}

// ─────────────────────────────────────────
//  VISITEUR — Registre des visiteurs
// ─────────────────────────────────────────

model Visiteur {
  id        String   @id @default(uuid())
  campId    String   @map("camp_id")
  nom       String
  prenom    String
  telephone String
  qualite   String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("visiteurs")
}

// ─────────────────────────────────────────
//  DON — Registre des dons reçus
// ─────────────────────────────────────────

// ─────────────────────────────────────────
//  ARTICLE SAC — Fouille des bagages
// ─────────────────────────────────────────

model ArticleSac {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  article       String
  quantite      Int      @default(1)
  categorie     String?
  confisque     Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("articles_sac")
}

// ─────────────────────────────────────────
//  ENSEIGNEMENT — Journal des enseignements
// ─────────────────────────────────────────

model Enseignement {
  id        String   @id @default(uuid())
  campId    String   @map("camp_id")
  date      DateTime
  orateur   String
  theme     String
  contenu   String   @db.Text
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("enseignements")
}

model Don {
  id          String   @id @default(uuid())
  campId      String   @map("camp_id")
  nom         String
  prenom      String
  telephone   String
  description String
  montant     Decimal? @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  camp Camp @relation(fields: [campId], references: [id], onDelete: Cascade)

  @@map("dons")
}
