# ─── Base de données ───────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/camp_manager"

# ─── Serveur ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_strong_random_secret_for_refresh
JWT_REFRESH_EXPIRES_IN=30d

# ─── Upload fichiers ───────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ─── Email (Nodemailer) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Camp Manager <no-reply@campmanager.com>

# ─── Admin par défaut (seed) ───────────────────────────────
ADMIN_EMAIL=admin@campmanager.com
ADMIN_PASSWORD=Admin1234!
